# ============================================================
# Docker Compose local development
# ============================================================

# Override DATABASE_URL to point to an external database (e.g. Neon) instead of
# the local Docker Postgres.  When using local compose, leave this commented out;
# docker-compose.yml sets DATABASE_URL to the containerised Postgres automatically.
# DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require&channel_binding=require

# Required: OpenAI API key for classification and embedding tasks
OPENAI_API_KEY=sk-...

# Optional: Django secret key (compose defaults to a dev-only key)
DJANGO_SECRET_KEY=dev-only-secret-key-change-me

# Required: Tenant ID sent as X-Tenant-ID header by the frontend
VITE_TENANT_ID=